#. §0: `theorem handshake_lemma (G : Graph) : sumDegrees G = 2 * edgeCount G`
#: Game.Levels.GraphTheory.L04_OddDegVerts
msgid "The sum of the degrees of the vertices is twice the number of the edges in a graph.\n"
"§0"
msgstr ""

#. §0: `induction`
#. §1: ```
#. induction G using graph_induction
#. ... (base case)
#. ... (inductive step)
#. ```
#: Game.Levels.GraphTheory.L03_Handshake
msgid "Helps you induct on graphs, one edge at a time. Use with the §0 tactic as follows:\n"
"## Usage:\n"
"§1\n"
"Immediately after the first line, the goal state will update to show the base case.\n"
"As soon as the base case is proven, the goal state will update to show the inductive case.\n"
"The induction assumption(s) will be usable as a named hypothesis (automatically named, visible above your goal state)\n"
"to prove the inductive case."
msgstr ""

#. §0: ```
#. -- multiset of degrees of each vertex
#. def DegreeContributions (G : Graph) := (Multiset.map (degree G) G.V.val)
#. ```
#. §1: `DegreeContributions G`
#. §2: `G`
#. §3: `{ ∀ v ∈ G.V, degree v }`
#: Game.Levels.GraphTheory.L04_OddDegVerts
msgid "§0\n"
"§1 returns a multiset (a set with possibly repeated elements) containing\n"
"the degrees of each vertex of the graph §2, i.e. §3"
msgstr ""

#. §0: ```
#. -- multiset of degrees of each vertex
#. def DegreeContributions (G : Graph) := (Multiset.map (degree G) G.V.val)
#. def EvenDegreeContributions (G : Graph) := (DegreeContributions G).filter (fun x => Even x)
